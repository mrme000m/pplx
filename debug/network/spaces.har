d`\\nEOF\",\"suggested_queries\":null,\"visual_concepts\":null,\"emoji\":\"\",\"access\":2,\"user_permission\":4,\"thread_count\":0,\"page_count\":0,\"slug\":\"setups-aOtvDSFPQBKaJFpShFtLLQ\",\"s3_social_preview_url\":\"https://ppl-ai-public.s3.amazonaws.com/previews/Setups-aOtvDSFPQBKaJFpShFtLLQ-preview-1715662971.png\",\"owner_user\":{\"username\":\"mrme000\",\"permission\":4,\"image\":\"https://imagedelivery.net/MPdwyYSWT8IY7lxgN3x3Uw/09205868-c76c-40ed-4431-b3b967433600/thumbnail\",\"email\":\"vb.mrme00@gmail.com\",\"name\":\"Hasib Rashid\"},\"contributor_users\":[],\"model_selection\":null,\"template_id\":null,\"file_count\":0,\"focused_web_config\":null,\"max_contributors\":null,\"enable_web_by_default\":true,\"knowledge_enabled\":false,\"knowledge_dream_instructions\":null,\"primers\":null,\"threads\":null,\"is_pinned\":null,\"is_invited\":null,\"space_type\":\"shared\",\"pending_join_request_status\":null,\"can_request_to_join\":null},{\"number\":26,\"has_next_page\":false,\"updated_datetime\":\"2025-04-10T17:31:41.573516\",\"uuid\":\"05cf393f-652c-4c31-8941-fc5e09bc63f6\",\"title\":\"IasC\",\"description\":\"\",\"instructions\":\"\",\"suggested_queries\":null,\"visual_concepts\":null,\"emoji\":\"\",\"access\":2,\"user_permission\":4,\"thread_count\":0,\"page_count\":0,\"slug\":\"iasc-Bc85P2UsTDGJQfxeCbxj9g\",\"s3_social_preview_url\":\"https://ppl-ai-public.s3.amazonaws.com/previews/iasc-Bc85P2UsTDGJQfxeCbxj9g-preview-1725304057.png\",\"owner_user\":{\"username\":\"mrme000\",\"permission\":4,\"image\":\"https://imagedelivery.net/MPdwyYSWT8IY7lxgN3x3Uw/09205868-c76c-40ed-4431-b3b967433600/thumbnail\",\"email\":\"vb.mrme00@gmail.com\",\"name\":\"Hasib Rashid\"},\"contributor_users\":[],\"model_selection\":null,\"template_id\":null,\"file_count\":0,\"focused_web_config\":null,\"max_contributors\":null,\"enable_web_by_default\":true,\"knowledge_enabled\":false,\"knowledge_dream_instructions\":null,\"primers\":null,\"threads\":null,\"is_pinned\":null,\"is_invited\":null,\"space_type\":\"shared\",\"pending_join_request_status\":null,\"can_request_to_join\":null},{\"number\":27,\"has_next_page\":false,\"updated_datetime\":\"2025-04-10T17:30:02.281544\",\"uuid\":\"84dba3a6-11a9-40cf-a01c-9b2183aa989e\",\"title\":\"4A1\",\"description\":\"for explaining to binbo\",\"instructions\":\"You are an adorable high-school teacher who whould explain things in simple and concise manner and leave option for knowing further \",\"suggested_queries\":null,\"visual_concepts\":null,\"emoji\":\"\",\"access\":2,\"user_permission\":4,\"thread_count\":0,\"page_count\":0,\"slug\":\"4a1-hNujphGpQM.gHJshg6qYng\",\"s3_social_preview_url\":\"https://ppl-ai-public.s3.amazonaws.com/previews/4A1-hNujphGpQM.gHJshg6qYng-preview-1713161259.png\",\"owner_user\":{\"username\":\"mrme000\",\"permission\":4,\"image\":\"https://imagedelivery.net/MPdwyYSWT8IY7lxgN3x3Uw/09205868-c76c-40ed-4431-b3b967433600/thumbnail\",\"email\":\"vb.mrme00@gmail.com\",\"name\":\"Hasib Rashid\"},\"contributor_users\":[],\"model_selection\":null,\"template_id\":null,\"file_count\":0,\"focused_web_config\":null,\"max_contributors\":null,\"enable_web_by_default\":true,\"knowledge_enabled\":false,\"knowledge_dream_instructions\":null,\"primers\":null,\"threads\":null,\"is_pinned\":null,\"is_invited\":null,\"space_type\":\"shared\",\"pending_join_request_status\":null,\"can_request_to_join\":null},{\"number\":28,\"has_next_page\":false,\"updated_datetime\":\"2025-04-10T17:28:54.312677\",\"uuid\":\"06b70a63-ba3c-4431-9a97-5f522fcab3bd\",\"title\":\"Mukta\",\"description\":\"\",\"instructions\":\"You are web site designer who makes custom profesional looking websites for small software companies selling custom software and solution\",\"suggested_queries\":null,\"visual_concepts\":null,\"emoji\":\"\",\"access\":2,\"user_permission\":4,\"thread_count\":0,\"page_count\":0,\"slug\":\"mukta-BrcKY7o8RDGal19SL8qzvQ\",\"s3_social_preview_url\":\"https://ppl-ai-public.s3.amazonaws.com/previews/Mukta-BrcKY7o8RDGal19SL8qzvQ-preview-1717447127.png\",\"owner_user\":{\"username\":\"mrme000\",\"permission\":4,\"image\":\"https://imagedelivery.net/MPdwyYSWT8IY7lxgN3x3Uw/09205868-c76c-40ed-4431-b3b967433600/thumbnail\",\"email\":\"vb.mrme00@gmail.com\",\"name\":\"Hasib Rashid\"},\"contributor_users\":[],\"model_selection\":null,\"template_id\":null,\"file_count\":0,\"focused_web_config\":null,\"max_contributors\":null,\"enable_web_by_default\":true,\"knowledge_enabled\":false,\"knowledge_dream_instructions\":null,\"primers\":null,\"threads\":null,\"is_pinned\":null,\"is_invited\":null,\"space_type\":\"shared\",\"pending_join_request_status\":null,\"can_request_to_join\":null},{\"number\":29,\"has_next_page\":false,\"updated_datetime\":\"2024-12-02T10:02:48.136423\",\"uuid\":\"26543e79-61f8-4fc2-ba48-926c64c3105b\",\"title\":\"Develop A Airbnb like Vacation Rental App\",\"description\":\"I want to build an mvp of a vacation rental app like airbnb for only hosting listings in Bangladesh including hotels, resorts and sorts.\\nI want use NextJS Shadcn and postgres or mongodb.\\nNow i want to build a custom AI agent than i can train on 10 github repo source code and then ask it to generate my mvp re-iteravely.\\nI wanna use google colab gpus to tain my AI agent and store the learning in some vetor database.\\nFirst I wanna analyse all github pulic repos created since 2023 to find the 10 best repos to train my model on.\\nSo first i need to generate a report and analysis of all the github repos for a airbnb clone find the repos that has the most features\\nimplemented, the most modern ui, the best cicd practices for testing and continious delivery of the code.\",\"instructions\":\"You are veteran developer who analyses different code bases and uses machine learning to generate code , documentation, and test for Building a MVP of airbnb like vacation rental app. You will help me in detail with the following in as detail as possible\\nI want to build an mvp of a vacation rental app like airbnb for only hosting listings in Bangladesh including hotels, resorts and sorts.\\nI want use NextJS Shadcn and postgres or mongodb.\\nNow i want to build a custom AI agent than i can train on 10 github repo source code and then ask it to generate my mvp re-iteravely.\\nI wanna use google colab gpus to tain my AI agent and store the learning in some vetor database.\\nFirst I wanna analyse all github pulic repos created since 2023 to find the 10 best repos to train my model on.\\nSo first i need to generate a report and analysis of all the github repos for a airbnb clone find the repos that has the most features\\nimplemented, the most modern ui, the best cicd practices for testing and continious delivery of the code.\",\"suggested_queries\":null,\"visual_concepts\":null,\"emoji\":\"\",\"access\":2,\"user_permission\":4,\"thread_count\":0,\"page_count\":0,\"slug\":\"develop-a-airbnb-like-vacation-JlQ.eWH4T8K6SJJsZMMQWw\",\"s3_social_preview_url\":null,\"owner_user\":{\"username\":\"mrme000\",\"permission\":4,\"image\":\"https://imagedelivery.net/MPdwyYSWT8IY7lxgN3x3Uw/09205868-c76c-40ed-4431-b3b967433600/thumbnail\",\"email\":\"vb.mrme00@gmail.com\",\"name\":\"Hasib Rashid\"},\"contributor_users\":[],\"model_selection\":null,\"template_id\":null,\"file_count\":0,\"focused_web_config\":null,\"max_contributors\":null,\"enable_web_by_default\":true,\"knowledge_enabled\":false,\"knowledge_dream_instructions\":null,\"primers\":null,\"threads\":null,\"is_pinned\":null,\"is_invited\":null,\"space_type\":\"shared\",\"pending_join_request_status\":null,\"can_request_to_join\":null}],\"next_cursor\":\"djI6bWFpbjozMA==\",\"total_count\":33},\"org_shared\":{\"items\":[],\"next_cursor\":null,\"total_count\":0}}}"
