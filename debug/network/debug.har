null,\"family_info\":null,\"provider\":null,\"user_connections\":[],\"migration\":null},{\"id\":\"midpage\",\"display_name\":\"Midpage\",\"description\":\"A law library for AI - search, analyze, and cite US case law with confidence\",\"type\":\"remote_mcp\",\"auth_type\":\"none\",\"icon_url\":\"https://r2cdn.perplexity.ai/sources/midpage/icon.svg\",\"capabilities\":{},\"connection_type\":null,\"query_rate_limit\":{\"monthly_limit\":5,\"remaining\":5},\"source_scope\":\"global\",\"auth_scope\":\"individual\",\"created_by_org_id\":null,\"created_by_user_id\":null,\"is_template\":false,\"required_fields\":null,\"source_details\":{\"tagline\":\"A law library for AI — search, analyze, and cite US case law with confidence.\",\"bullets\":[\"Search US case law across all federal and state courts using keywords, natural language questions, boolean queries, or legal propositions, with filters for jurisdiction, date, and publication status\",\"Find quotable passages within any opinion using fast keyword search — useful for quickly checking whether a case is relevant before committing to deeper analysis\",\"Analyze opinions with AI to extract verified holdings, cite-ready propositions with pinpoint citations, verbatim quotes, scope limitations, and citator treatment (positive/negative/caution/neutral) — required before citing any case\",\"Check citator status to confirm whether a case is still good law, with treatment data and citation counts drawn from a graph of 90 million links between cases\",\"Generate properly cited legal writing with Bluebook-formatted citations and shareable Midpage links that point to exact sentence ranges in the opinion text\"],\"consumer_bullets\":null,\"connected_bullets\":null,\"developer\":null,\"website_url\":\"https://www.midpage.ai/\",\"support_url\":\"https://www.midpage.ai/contact-sales\",\"documentation_url\":\"https://www.midpage.ai/data\",\"footnote\":null,\"setup_steps\":[]},\"display_categories\":[\"Legal\"],\"is_popular\":false,\"popularity\":null,\"is_created_by_current_user\":false,\"is_user_selectable\":true,\"is_premium\":true,\"is_consumer_only\":false,\"supported_exec_envs\":[],\"template_source_id\":null,\"extra_config\":null,\"org_disabled\":null,\"setup_descriptor\":null,\"viewer_setup_state\":null,\"family_info\":null,\"provider\":\"direct\",\"user_connections\":[],\"migration\":null},{\"id\":\"bmj\",\"display_name\":\"The BMJ\",\"description\":\"The BMJ is an international medical journal and healthcare knowledge platform with a mission to work toward a healthier world for all. It serves clinicians, researchers, educators, policymakers, patients, and the public through research evidence, clinical education, health policy commentary, investigations, multimedia, and live formats.\",\"type\":\"other\",\"auth_type\":\"none\",\"icon_url\":\"https://r2cdn.perplexity.ai/sources/bmj/icon.svg\",\"capabilities\":{},\"connection_type\":null,\"query_rate_limit\":null,\"source_scope\":\"global\",\"auth_scope\":\"individual\",\"created_by_org_id\":null,\"created_by_user_id\":null,\"is_template\":false,\"required_fields\":null,\"source_details\":{\"tagline\":null,\"bullets\":[\"Global medical journal and platform: The BMJ describes itself as an international research journal, member magazine, think tank, investigative campaigner, educational resource, and trusted health publication.\",\"Focused on evidence and care quality: It emphasizes improving research evidence, clinical education, clinical practice, and universal, equitable, high-quality healthcare.\",\"Broad healthcare audience: The BMJ reaches readers across clinical practice, research, education, government, patients, and the public, using formats including print, website, app, podcast, video, social media, and live events.\"],\"consumer_bullets\":null,\"connected_bullets\":null,\"developer\":null,\"website_url\":\"https://www.bmj.com/\",\"support_url\":null,\"documentation_url\":null,\"footnote\":null,\"setup_steps\":[]},\"display_categories\