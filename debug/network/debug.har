          "cookies": [],
          "content": {
            "mimeType": "application/json",
            "size": 4051,
            "text": "{\"tasks\":[{\"task_id\":\"6ba7b8109dad11d180b400c04fd430c8\",\"task_name\":\"teach-me-comet\",\"prompt\":\"Teach me how to use Comet based on my browsing and query history, highlight the most recent feature updates, suggest five personalized and specific queries I should try, and surface the most compelling use case and prompt examples shared on social media.\",\"model_preference\":\"pplx_pro\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null},{\"task_id\":\"a1b2c3d4e5f6789012345678901234ab\",\"task_name\":\"trending-on-social\",\"prompt\":\"I want to know about the latest trending topics. Scroll through each of my social media websites that I'm logged into, review the posts from the past 24 hours and summarize the trending events.\",\"model_preference\":\"pplx_pro\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null},{\"task_id\":\"9e8d7c6b5a49382716051234567890ef\",\"task_name\":\"evaluate-this-deal\",\"prompt\":\"Evaluate whether this is a good deal by checking its price history over time, comparing current pricing across other major retailers, and analyzing recent customer reviews for patterns in quality, reliability, and satisfaction. Highlight any red flags or standout features, and let me know if now is the best time to buy or if I should wait for a better price.\",\"model_preference\":\"pplx_pro\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null},{\"task_id\":\"b1c2d3e4f5a6789012345678901234cd\",\"task_name\":\"prep-next-meeting\",\"prompt\":\"Help me prepare for my next meeting by listing the participants, outlining the meeting goals and agenda, highlighting anything I should review or prepare, and suggesting questions I could ask. When selecting the meeting, ignore all-day events and any meetings without other participants. If any participants are external to my company, include a brief bio.\",\"model_preference\":\"pplx_pro\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null},{\"task_id\":\"c2d3e4f5a6b7890123456789012345de\",\"task_name\":\"write\",\"prompt\":\"Take this rough idea or sentence and develop it into a compelling paragraph or argument. Maintain the original intent, but add nuance, evidence, or examples to strengthen it. Sound confident and clear.\",\"model_preference\":\"pplx_pro\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null},{\"task_id\":\"a1b2c3d4e5f67890abcdef1234567890\",\"task_name\":\"sonar\",\"prompt\":\"\",\"model_preference\":\"experimental\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null},{\"task_id\":\"f47ac10b58cc4372a5678d33d5e8a92a\",\"task_name\":\"claude-4-0-sonnet\",\"prompt\":\"\",\"model_preference\":\"claude2\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null},{\"task_id\":\"5a8b9c2d3e4f5678901a2b3c4d5e6f78\",\"task_name\":\"gpt5\",\"prompt\":\"\",\"model_preference\":\"gpt5\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null},{\"task_id\":\"3e4666bf9f7f4136885bbe999c1a7b23\",\"task_name\":\"gemini-2-5-pro-06-05\",\"prompt\":\"\",\"model_preference\":\"gemini2flash\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null},{\"task_id\":\"9c8e4f2a1b3d4c5e6f789012a3b4c5d6\",\"task_name\":\"o3\",\"prompt\":\"\",\"model_preference\":\"o3\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null},{\"task_id\":\"b8f3a2d1c4e5f6789012345678901234\",\"task_name\":\"claude-4-0-sonnet-thinking\",\"prompt\":\"\",\"model_preference\":\"claude37sonnetthinking\",\"sources\":[\"web\"],\"preconfigured\":true,\"created_at\":\"2025-07-16T00:00:00\",\"updated_at\":\"2025-07-16T00:00:00\",\"metadata\":null}]}"
