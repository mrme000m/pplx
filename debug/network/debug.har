            "text": "{\"sources\":[{\"id\":\"finance\",\"display_name\":\"Perplexity Finance\",\"description\":\"Built-in finance tools\",\"type\":\"other\",\"auth_type\":\"none\",\"icon_url\":\"https://r2cdn.perplexity.ai/sources/finance/icon.svg\",\"capabilities\":{},\"connection_type\":null,\"query_rate_limit\":null,\"source_scope\":\"global\",\"auth_scope\":\"system\",\"created_by_org_id\":\"e54437c8-7e1d-42e2-a70e-7b55f77ae177\",\"created_by_user_id\":\"73191977\",\"is_template\":false,\"required_fields\":null,\"source_details\":{\"tagline\":\"Built-in tools\",\"bullets\":[\"Access market data, quotes, earnings, financials, analyst data, macro data, ETF holdings, and politician trading data.\"],\"consumer_bullets\":null,\"connected_bullets\":null,\"developer\":\"Perplexity\",\"website_url\":\"https://www.perplexity.ai/finance\",\"support_url\":\"https://www.perplexity.ai/hub/helpcenter\",\"documentation_url\":null,\"footnote\":{\"link\":\"https://www.perplexity.ai/hub/helpcenter\",\"text\":\"Financial information provided by Financial Modeling Prep. Options data provided by Unusual Whales. Earnings transcripts, audio, and documents provided by Quartr. Reported revenue and EPS data from Earnings powered by Fiscal.ai. Estimates provided by S&P Global. Prediction markets data from Polymarket. Charting for Perplexity Computer financial visualizations provided by TradingView, where applicable. All data is provided for informational purposes only, and is not intended for trading purposes or financial, investment, tax, legal, accounting or other advice.\"},\"setup_steps\":[]},\"display_categories\":[],\"is_popular\":false,\"popularity\":null,\"is_created_by_current_user\":false,\"is_user_selectable\":true,\"is_premium\":false,\"is_consumer_only\":false,\"supported_exec_envs\":[\"native_api\"],\"template_source_id\":null,\"extra_config\":null,\"org_disabled\":null,\"setup_descriptor\":null,\"viewer_setup_state\":null,\"family_info\":null,\"provider\":null,\"user_connec